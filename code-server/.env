# ── User / Group ──────────────────────────────────────────────────────────────
# Run `id` on the host to find your UID and GID.
PUID=1000
PGID=1000

# ── Timezone ───────────────────────────────────────────────────────────────────
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Etc/UTC

# ── Authentication (choose one or leave blank for no password) ─────────────────
# Plain-text password
PASSWORD=

# bcrypt hash of the password (takes precedence over PASSWORD).
# Generate with:  echo -n "mypassword" | htpasswd -niBC 10 "" | tr -d ':\n'
HASHED_PASSWORD=

# Sudo password for the `abc` user inside the container
SUDO_PASSWORD=

# bcrypt hash of the sudo password (takes precedence over SUDO_PASSWORD)
SUDO_PASSWORD_HASH=

# ── Reverse-proxy ──────────────────────────────────────────────────────────────
# Set to the domain you expose code-server on (e.g. code.example.com)
PROXY_DOMAIN=

# ── Port ───────────────────────────────────────────────────────────────────────
# Host port that maps to the container's 8443
PORT=8443

# ── Default workspace ─────────────────────────────────────────────────────────
# The folder opened by default when code-server starts.
# /workspaces is the parent directory mounted in docker-compose.yaml.
DEFAULT_WORKSPACE=/workspaces
